Options -Indexes -MultiViews

RewriteEngine On

# Keep the current no-trailing-slash URL shape when serving static export files.
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Next static export emits clean routes as .html files.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]

# Let Apache serve real files and folders first.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

ErrorDocument 404 /404.html
